{
  "appId": "com.chronomed.app",
  "appName": "ChronoMed",
  "webDir": "dist",
  "server": {
    "androidScheme": "https"
  },
  "android": {
    "allowMixedContent": false,
    "backgroundColor": "#0f172a",
    "buildOptions": {
